# Permite importar el paquete src al ejecutar desde la raiz del proyecto.
PYTHONPATH=.

# Reproducibilidad basica.
PYTHONHASHSEED=42

# Mantiene TensorFlow Datasets en la carpeta data/ de la raiz capstone/.
TFDS_DATA_DIR=./data/tensorflow_datasets

# Mantiene pesos descargados y configuracion de Keras dentro del proyecto Python.
KERAS_HOME=./data/keras

# Oculta mensajes informativos de TensorFlow; conserva warnings y errores.
TF_CPP_MIN_LOG_LEVEL=1


DB_HOST=localhost
DB_PORT=5432
DB_NAME=malaria_experiments
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/malaria_experiments
